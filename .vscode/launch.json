{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Thereabout Backend (Development)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/backend/mvnw",
            "runtimeArgs": [
                "-s", "${workspaceFolder}/maven-settings.xml",
                "spring-boot:run",
                "-Dspring-boot.run.profiles=development",
                "-Dspring-boot.run.jvmArguments=-Dserver.port=9050"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Thereabout Backend (Production DB)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/backend/mvnw",
            "runtimeArgs": [
                "-s", "${workspaceFolder}/maven-settings.xml",
                "spring-boot:run",
                "-Dspring-boot.run.profiles=development-prod-db",
                "-Dspring-boot.run.jvmArguments=-Dserver.port=9050"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "name": "Thereabout Frontend (Development)",
            "request": "launch",
            "program": "${workspaceFolder}/frontend/node_modules/@angular/cli/bin/ng",
            "args": [
                "serve",
                "--proxy-config",
                "src/proxy.conf.json"
            ],
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "NODE_ENV": "development"
            },
            "preLaunchTask": "npm: install",
            "presentation": {
                "hidden": false,
                "group": "frontend",
                "order": 1
            }
        },
        {
            "name": "Run All Controller Tests",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/backend/mvnw",
            "runtimeArgs": [
                "-s", "${workspaceFolder}/maven-settings.xml",
                "test", "-Dtest=*ControllerTest"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Run All Tests",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/backend/mvnw",
            "runtimeArgs": [
                "-s", "${workspaceFolder}/maven-settings.xml",
                "test"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        }
    ]
}
