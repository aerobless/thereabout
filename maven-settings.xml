<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
    <!--
      Project-local Maven settings. Use this when running or building from IDEs
      so dependency resolution uses only Maven Central and MCHV (e.g. for TDLight),
      and does not go through a corporate Nexus mirror that may not have all artifacts.
      In IntelliJ: Settings → Build, Execution, Deployment → Build Tools → Maven →
      User settings file → Override → select this file.
    -->
    <profiles>
        <profile>
            <id>thereabout</id>
            <repositories>
                <repository>
                    <id>central</id>
                    <url>https://repo.maven.apache.org/maven2</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>false</enabled></snapshots>
                </repository>
                <repository>
                    <id>mchv</id>
                    <name>MCHV Apache Maven Packages</name>
                    <url>https://mvn.mchv.eu/repository/mchv/</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>false</enabled></snapshots>
                </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>central</id>
                    <url>https://repo.maven.apache.org/maven2</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>false</enabled></snapshots>
                </pluginRepository>
            </pluginRepositories>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>thereabout</activeProfile>
    </activeProfiles>
</settings>
